WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
MYSQL_ROOT_PASSWORD=changeme
WORDPRESS_TABLE_PREFIX=wp_
HEADLESS=false
# Comma-separated list of allowed frontend origins (local, preview, production).
# Example: http://localhost:3000,https://myapp.amplifyapp.com
FRONTEND_URLS=http://localhost:3000,https://myapp.amplifyapp.com
# Backwards-compatible single frontend URL (optional)
FRONTEND_URL=http://localhost:3000
## Optional: set host user UID/GID to avoid permission issues when using bind mounts
# On macOS your user UID is usually 501; on Linux it's often 1000. Set these to match your host user:
# PUID=501
# PGID=20

WORDPRESS_SITE_URL=http://localhost:8000
WORDPRESS_SITE_TITLE=WordPress
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=admin
WORDPRESS_ADMIN_EMAIL=admin@example.com
PUID=501
PGID=20